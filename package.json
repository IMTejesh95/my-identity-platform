    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "jose": "^5.0.0",
    "oidc-provider": "^8.0.0",
    "pg": "^8.20.0",
    "pino": "^8.0.0",
    "pino-http": "^9.0.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/oidc-provider": "^9.5.0",
    "prisma": "^5.22.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  },
  "compilerOptions": {
    "target": "ES2020",
